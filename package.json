{
  "name": "oracle-access-request-lookup",
  "version": "1.2.0",
  "description": "Oracle Access Request Lookup desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.yourorg.oracle-access-request-lookup",
    "productName": "Oracle Access Request Lookup",
    "icon": "assets/icon",
    "publish": {
      "provider": "github",
      "owner": "JessamynR",
      "repo": "oracle_tools",
      "releaseType": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "assets/**",
      "node_modules/xlsx/**",
      "node_modules/electron-updater/**"
    ],
    "mac": {
      "category": "public.app-category.business",
      "icon": "assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ]
    },
    "dmg": {
      "title": "Oracle Access Request Lookup"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerHeaderIcon": null
    }
  },
  "devDependencies": {
    "electron": "^40.6.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "xlsx": "^0.18.5"
  }
}
